generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductionType {
  HT
  HK
}

enum QCStatus {
  PENDING
  DONE
}

enum UserRole {
  ADMIN
  QC
  WAREHOUSE
  DEFLASHING
}

enum DeflashingStatus {
  PENDING
  DONE
}

enum WipProductionType {
  HT
  HK
}

//
// USER
//
model User {
  id       String   @id @default(cuid())
  username String   @unique
  password String
  role     UserRole @default(WAREHOUSE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// PRODUCT MASTER
//
model Product {
  id           String @id @default(cuid())
  computerCode String @unique @db.VarChar(50)
  partNo       String @db.VarChar(50)
  productName  String @db.VarChar(255)

  productionType ProductionType @default(HT)
  location       String?        @db.VarChar(100)
  initialStock   Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomingTransactions IncomingTransaction[]
  afterOQCTransactions AfterOQCTransaction[]
  outgoingTransactions OutgoingTransaction[]
}

//
// RECEIVING (INCOMING)
//
model IncomingTransaction {
  id String @id @default(cuid())

  date DateTime @default(now())

  computerCode String @db.VarChar(50)
  partNo       String @db.VarChar(50)
  productName  String @db.VarChar(255)

  incomingQty Int @default(0)

  outgoingQty Int @default(0)
  balance     Int @default(0)

  remainingQty Int?
  status       String? @default("OPEN")

  batch             String? @db.VarChar(50)
  responsiblePerson String  @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [computerCode], references: [computerCode], onDelete: Cascade)

  afterOQC AfterOQCTransaction[]

  outHistories IncomingOutHistory[] // 🔥 INI WAJIB

  @@index([computerCode])
  @@index([date])
}

model IncomingOutHistory {
  id String @id @default(cuid())

  incomingId String
  incoming   IncomingTransaction @relation(fields: [incomingId], references: [id], onDelete: Cascade)

  qtyOut            Int
  responsiblePerson String

  createdAt DateTime @default(now())

  @@index([incomingId]) // ✅ tambah ini
}

//
// QC MASTER
//
model AfterOQCTransaction {
  id String @id @default(cuid())

  date DateTime @default(now())

  computerCode String @db.VarChar(50)
  partNo       String @db.VarChar(50)
  productName  String @db.VarChar(255)

  batch String? @db.VarChar(50)

  beforeQty Int
  afterQty  Int @default(0)
  ngQty     Int @default(0)
  bufferQty Int @default(0)
  looseQty  Int @default(0)
  otherQty  Int @default(0)

  status QCStatus @default(PENDING)

  source String @default("INCOMING") @db.VarChar(20)

  responsiblePerson String? @db.VarChar(100)

  incomingId String?
  incoming IncomingTransaction? @relation(fields: [incomingId], references: [id], onDelete: Cascade)

product Product @relation(fields: [computerCode], references: [computerCode], onDelete: Cascade)

  logs AfterOQCLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([computerCode])
  @@index([status])
}

model AfterOQCLog {
  id String @id @default(cuid())

  afterOQCId String

  afterOQC AfterOQCTransaction @relation(fields: [afterOQCId], references: [id], onDelete: Cascade)

  okQty Int @default(0)
  ngQty Int @default(0)
  looseQty Int @default(0)
  bufferQty Int @default(0)
  otherQty Int @default(0)

  responsiblePerson String? @db.VarChar(100)

  createdAt DateTime @default(now())

  @@index([afterOQCId])
}

model OutgoingTransaction {
  id String @id @default(cuid())

  date DateTime @default(now())

  computerCode String? @db.VarChar(50)
  partNo       String? @db.VarChar(50)
  productName  String? @db.VarChar(255)

  qtyOut            Int
  responsiblePerson String @db.VarChar(100)

  remark String? @db.VarChar(255)

  product Product? @relation(fields: [computerCode], references: [computerCode], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([computerCode])
  @@index([date])
}

//
// DEFLASHING
//
model Deflashing {
  id String @id @default(cuid())

  incomingDate DateTime @default(now())

  computerCode String
  partNo       String
  productName  String

  productionType ProductionType @default(HT)

  qtyIn        Int
  processedQty Int @default(0)

  status DeflashingStatus @default(PENDING)

  incomingBy  String
  processedBy String?

  batchNo String? @db.VarChar(50)

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  logs DeflashingProcessLog[]

  @@index([status])
}

model DeflashingProcessLog {
  id String @id @default(cuid())

  deflashingId String
  deflashing   Deflashing @relation(fields: [deflashingId], references: [id], onDelete: Cascade)

  batchNo String? @db.VarChar(50)

  qtyOut   Int
  ngQty    Int
  spareQty Int

  processedBy String
  processedAt DateTime @default(now())

  @@index([deflashingId])
  @@index([batchNo])
}

//
// WIP PRODUCT MASTER
//
model WipProduct {
  id String @id @default(cuid())

  computerCode String @unique @db.VarChar(50)
  partNo       String @db.VarChar(50)
  productName  String @db.VarChar(255)

  type WipProductionType @default(HT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ FIX DI SINI
  stock     WipStock?
  incomings WipIncoming[]
  outgoings WipOutgoing[]

  @@index([type])
}

//
// WIP STOCK (INI YANG JADI TABEL EXCEL LU 🔥)
//
model WipStock {
  id String @id @default(cuid())

  productId String     @unique
  product   WipProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  initialStock Int @default(0)
  incomingQty  Int @default(0)
  outgoingQty  Int @default(0)
  finalStock   Int @default(0)

  updatedAt DateTime @updatedAt

  @@index([productId])
}

//
// WIP INCOMING
//
model WipIncoming {
  id String @id @default(cuid())

  date DateTime @default(now())

  productId String
  product   WipProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  qty Int

  createdBy String // Responsible Person
  ipqc      String? // IPQC PIC ✅
  remark    String? // Remark ✅

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([date])
}

//
// WIP OUTGOING
//
model WipOutgoing {
  id String @id @default(cuid())

  date DateTime @default(now())

  productId String
  product   WipProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  qty Int

  remark    String?
  createdBy String

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([date])
}

enum RawMaterialStatus {
  ACTIVE
  EMPTY
  EXPIRED
}

model RawMaterial {
  id String @id @default(cuid())

  materialCode String @unique @db.VarChar(50)
  materialName String @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches RawMaterialBatch[]

  @@index([materialCode])
}

model RawMaterialBatch {
  id String @id @default(cuid())

  rawMaterialId String

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  incomingDate DateTime @default(now())

  lotNo String @db.VarChar(100)

  incomingQty Int @default(0)

  incomingWeight Float @default(0)

  spq Float @default(0)

  balanceQty Int @default(0)

  balanceWeight Float @default(0)

  warehouse String @db.VarChar(50)

  expDate DateTime

  status RawMaterialStatus @default(ACTIVE)

  createdBy String @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages RawMaterialUsage[]

  @@index([rawMaterialId])
  @@index([lotNo])
  @@index([warehouse])
  @@index([expDate])
  @@index([status])
}

model RawMaterialUsage {
  id String @id @default(cuid())

  batchId String

  batch RawMaterialBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  usageDate DateTime @default(now())

  qtyUsed    Int   @default(0)
  weightUsed Float @default(0)

  balanceQtyBefore Int
  balanceQtyAfter  Int

  balanceWeightBefore Float
  balanceWeightAfter  Float

  workOrder String? @db.VarChar(100)
  machineNo String? @db.VarChar(50)

  remark String? @db.VarChar(255)

  createdBy String @db.VarChar(100)

  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([usageDate])
  @@index([createdBy])
}
