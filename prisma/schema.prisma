generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductionType {
  HT
  HK
}

enum QCStatus {
  PENDING
  DONE
}

enum UserRole {
  ADMIN
  QC
  WAREHOUSE
  DEFLASHING
}

enum DeflashingStatus {
  PENDING
  DONE
}

//
// USER
//
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      UserRole @default(WAREHOUSE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// PRODUCT MASTER
//
model Product {
  id             String   @id @default(cuid())
  computerCode   String   @unique @db.VarChar(50)
  partNo         String   @db.VarChar(50)
  productName    String   @db.VarChar(255)

  productionType ProductionType @default(HT)
  location       String? @db.VarChar(100)
  initialStock   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomingTransactions IncomingTransaction[]
  afterOQCTransactions AfterOQCTransaction[]
  outgoingTransactions OutgoingTransaction[]
}

//
// RECEIVING (INCOMING)
//
model IncomingTransaction {
  id String @id @default(cuid())

  date DateTime @default(now())

  computerCode String @db.VarChar(50)
  partNo       String @db.VarChar(50)
  productName  String @db.VarChar(255)

  incomingQty Int @default(0)

  // legacy
  outgoingQty Int @default(0)
  balance     Int @default(0)

  remainingQty Int?
  status       String? @default("OPEN")

  batch Int @default(0)
  responsiblePerson String @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [computerCode], references: [computerCode], onDelete: Cascade)

  afterOQC   AfterOQCTransaction[]
  deflashings Deflashing[]   // ✅ FIX RELATION (WAJIB ADA)

  @@index([computerCode])
  @@index([date])
}

//
// QC MASTER
//
model AfterOQCTransaction {
  id String @id @default(cuid())

  date DateTime @default(now())

  computerCode String @db.VarChar(50)
  partNo       String @db.VarChar(50)
  productName  String @db.VarChar(255)

  batch Int? // ✅ TAMBAHKAN INI

  beforeQty Int
  afterQty  Int @default(0)
  ngQty     Int @default(0)
  spareQty  Int @default(0)

  status QCStatus @default(PENDING)

  source String @default("INCOMING") @db.VarChar(20)

  responsiblePerson String? @db.VarChar(100)

  incomingId String
  incoming   IncomingTransaction @relation(fields: [incomingId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [computerCode], references: [computerCode], onDelete: Cascade)

  logs AfterOQCLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([computerCode])
  @@index([status])
}

//
// QC DETAIL LOG
//
model AfterOQCLog {
  id String @id @default(cuid())

  afterOQCId String
  afterOQC   AfterOQCTransaction @relation(fields: [afterOQCId], references: [id], onDelete: Cascade)

  okQty    Int @default(0)
  ngQty    Int @default(0)
  spareQty Int @default(0)

  responsiblePerson String? @db.VarChar(100)

  createdAt DateTime @default(now())

  @@index([afterOQCId])
}

model OutgoingTransaction {
  id String @id @default(cuid())

  date DateTime @default(now())

  computerCode String? @db.VarChar(50)
  partNo       String? @db.VarChar(50)
  productName  String? @db.VarChar(255)

  qtyOut Int
  responsiblePerson String @db.VarChar(100)

  remark String? @db.VarChar(255)

  product Product? @relation(fields: [computerCode], references: [computerCode], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([computerCode])
  @@index([date])
}

//
// DEFLASHING
//
model Deflashing {
  id String @id @default(cuid())

  incomingId String
  incoming IncomingTransaction @relation(fields: [incomingId], references: [id], onDelete: Cascade)

  incomingDate DateTime @default(now())

  computerCode String
  partNo       String
  productName  String

  productionType ProductionType @default(HT)

  qtyIn        Int
  processedQty Int @default(0)

  status DeflashingStatus @default(PENDING)

  incomingBy  String
  processedBy String?

  batchNo Int?   // 🔥 TAMBAHKAN INI

  createdAt   DateTime @default(now())
  completedAt DateTime?

  logs DeflashingProcessLog[]

  @@index([status])
  @@index([incomingId])
}
model DeflashingProcessLog {
  id String @id @default(cuid())

  deflashingId String
  deflashing   Deflashing @relation(fields: [deflashingId], references: [id], onDelete: Cascade)

  batchNo Int?   // ✅ TAMBAHKAN INI

  qtyOut   Int
  ngQty    Int
  spareQty Int

  processedBy String
  processedAt DateTime @default(now())

  @@index([deflashingId])
  @@index([batchNo])   // opsional tapi bagus untuk query
}